<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SardarJi" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/sj_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/sj_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>

    <style name="Theme.SardarJi.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sj_brand_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenAnimationDuration">250</item>
        <item name="postSplashScreenTheme">@style/Theme.SardarJi</item>
    </style>
</resources>
